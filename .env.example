
# Admin login (change these before deploying!)
ADMIN_USERNAME=kitaberaofficial
ADMIN_PASSWORD=change-this-password
JWT_SECRET=change-this-to-a-long-random-string

# Server
PORT=4000

# Firebase — get these from Firebase Console > Project Settings > Service Accounts
# > "Generate new private key" (downloads a JSON file with these exact fields).
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
# Paste the private_key value from the JSON file. Keep the \n characters literal
# (do not replace them with real line breaks) — the app converts them automatically.
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvQ...\n-----END PRIVATE KEY-----\n"
# Firebase Console > Storage > it's shown at the top, usually "your-project-id.appspot.com"
FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
